# ════════════════════════════════════════════════════════════════
#  ThreatMind AI — Environment Configuration (example)
#  Copy to `.env` and adjust. NEVER commit your real .env.
#  All services here are free / open-source. No paid keys required.
# ════════════════════════════════════════════════════════════════

# ─── General ──────────────────────────────────────────────────
ENVIRONMENT=development                 # development | staging | production
DEBUG=true
PROJECT_NAME=ThreatMind AI
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                          # true for structured JSON logs (prod)

# ─── API server ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Security / JWT ───────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-a-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Fernet key for encryption-at-rest of sensitive fields.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# MFA (TOTP)
MFA_ISSUER=ThreatMind AI

# Rate limiting (requests per window per client)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=threatmind
POSTGRES_PASSWORD=threatmind_dev_password
POSTGRES_DB=threatmind
POSTGRES_HOST=localhost                 # use "postgres" inside Docker network
POSTGRES_PORT=5432
# Full async DSN is derived in settings; override only if needed.
# DATABASE_URL=postgresql+asyncpg://threatmind:threatmind_dev_password@localhost:5432/threatmind

# ─── Redis (cache + message bus + agent memory) ───────────────
REDIS_HOST=localhost                    # use "redis" inside Docker network
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# ─── Elasticsearch (log/event search) ─────────────────────────
ELASTICSEARCH_URL=http://localhost:9200  # use http://elasticsearch:9200 in Docker
ELASTICSEARCH_INDEX_PREFIX=threatmind

# ─── Ollama (local LLM — FREE) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434   # use http://ollama:11434 in Docker
OLLAMA_MODEL=llama3.1                    # default model for agents
OLLAMA_EMBEDDING_MODEL=nomic-embed-text  # for semantic search / RAG
LLM_PROVIDER=ollama                      # pluggable: ollama (default)
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120

# ─── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ThreatMind AI

# ─── Observability ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true
