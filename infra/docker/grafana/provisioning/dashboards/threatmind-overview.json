{
  "annotations": { "list": [] },
  "editable": true,
  "title": "ThreatMind AI — Platform Overview",
  "uid": "threatmind-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(threatmind_http_requests_total[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(threatmind_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent runs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(threatmind_agent_runs_total[5m])) by (agent)", "legendFormat": "{{agent}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM request latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(threatmind_llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
